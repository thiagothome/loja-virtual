@page
@model SiteAspas.Pages.CadastrarProdutoModel
@{
    Layout = "_Layout";
    ViewData["HideHeader"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/cadastrarProduto.css">
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2 class="auth-title">Cadastrar Novo Produto</h2>
            <p class="auth-subtitle">Preencha os dados do produto</p>
        </div>

        <form method="post" enctype="multipart/form-data" class="auth-form">
            <div class="form-group">
                <label asp-for="Produto.Nome" class="form-label">Nome do Produto</label>
                <input asp-for="Produto.Nome" class="form-input" placeholder="Nome do produto" required />
                <span asp-validation-for="Produto.Nome" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Produto.Descricao" class="form-label">Descrição</label>
                <textarea asp-for="Produto.Descricao" class="form-input" placeholder="Descrição do produto" rows="3"></textarea>
                <span asp-validation-for="Produto.Descricao" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Produto.Preco" class="form-label">Preço</label>
                <input asp-for="Produto.Preco" type="number" step="0.01" class="form-input" placeholder="0.00" required />
                <span asp-validation-for="Produto.Preco" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImagemProduto" class="form-label">Imagem do Produto</label>
                <input asp-for="ImagemProduto" type="file" class="form-input" />
                <span asp-validation-for="ImagemProduto" class="form-error"></span>
            </div>

            <button type="submit" class="auth-button">
                <span class="button-text">Cadastrar Produto</span>
                <span class="button-loader">
                    <i class="fas fa-spinner fa-spin"></i>
                </span>
            </button>
        </form>
    </div>
</div>