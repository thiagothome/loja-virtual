@page
@model CadastrarUsuarioModel
@{
    Layout = "_Layout";
    ViewData["HideHeader"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/cadastrar.css">
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2 class="auth-title">Criar nova conta</h2>
            <p class="auth-subtitle">Preencha seus dados para se cadastrar</p>
        </div>

        <form method="post" class="auth-form">
            <div class="form-group">
                <label for="Nome" class="form-label">Nome</label>
                <input asp-for="Usuario.Nome" type="text" class="form-input" placeholder="Seu primeiro nome"/>
                <span asp-validation-for="Usuario.Nome" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label for="Sobrenome" class="form-label">Sobrenome</label>
                <input asp-for="Usuario.Sobrenome" type="text" class="form-input" placeholder="Seu Sobrenome" />
                <span asp-validation-for="Usuario.Sobrenome" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label for="Email" class="form-label">E-mail</label>
                <input asp-for="Usuario.Email" type="email" class="form-input" placeholder="seu@email.com" />
                <span asp-validation-for="Usuario.Email" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label asp-for="Telefone" class="form-label">Telefone</label>
                <input asp-for="Telefone" type="tel" class="form-input"
                       placeholder="(11) 99999-9999"
                       pattern="^\(?\d{2}\)?[\s-]?\d{4,5}-?\d{4}$" />
                <span asp-validation-for="Telefone" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label for="Senha" class="form-label">Senha</label>
                <div class="password-input">
                    <input asp-for="Senha" type="password" class="form-input" placeholder="••••••••" value="@ViewData["Senha"]" />
                    <button type="button" class="password-toggle">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Senha" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label for="ConfirmarSenha" class="form-label">Confirmar Senha</label>
                <div class="password-input">
                    <input asp-for="ConfirmarSenha" type="password" class="form-input" placeholder="••••••••" value="@ViewData["ConfirmarSenha"]"/>
                    <button type="button" class="password-toggle">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmarSenha" class="erroValidacao"></span>
            </div>

            <button type="submit" class="auth-button">
                <span class="button-text">Cadastrar</span>
                <span class="button-loader">
                    <i class="fas fa-spinner fa-spin"></i>
                </span>
            </button>

            <div class="auth-divider">
                <span>ou</span>
            </div>

            <button type="button" class="social-button google-button">
                <i class="fab fa-google"></i>
                Continuar com Google
            </button>
        </form>

        <div class="auth-footer">
            <p>Já tem uma conta? <a asp-page="/Conta/Entrar" class="auth-link">Entrar agora</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/site.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script>
        $(document).ready(function(){
            $('#Telefone').mask('(00) 00000-0000');
        });
    </script>
}
