@page
@model SiteAspas.Pages.ConfirmarEmailModel
@{
    ViewData["Title"] = "Confirmação de E-mail";
}

<div class="container">
    <h2>Confirmação de E-mail</h2>
    @if (Model.Sucesso)
    {
        <div class="alert alert-success">Seu e-mail foi confirmado com sucesso!</div>
        <div><a asp-page="/Conta/Entrar">Ir para login</a></div>
    }
    else
    {
        <div class="alert alert-danger">Não foi possível confirmar seu e-mail. O link pode estar inválido ou expirado.</div>
    }
</div>
