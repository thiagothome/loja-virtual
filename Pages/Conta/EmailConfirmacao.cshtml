@page
@model SiteAspas.Pages.EmailConfirmacaoModel
@{
    ViewData["Title"] = "Confirmação de E-mail";
}

<div class="container">
    <h2>Confirmação de E-mail Enviada</h2>
    <p>Enviamos um link de confirmação para <strong>@Model.Email</strong>.</p>
    <p>Por favor, verifique sua caixa de entrada e clique no link para ativar sua conta.</p>

    <div class="alert alert-info mt-4">
        <p>Não recebeu o e-mail?</p>
        <form method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">Reenviar E-mail</button>
        </form>
    </div>
</div>