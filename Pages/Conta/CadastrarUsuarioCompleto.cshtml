@page
@model SiteAspas.Pages.Conta.CadastrarUsuarioCompletoModel
@{
    Layout = "_Layout";
    ViewData["HideHeader"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/cadastrarUsuarioCompleto.css">
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2 class="auth-title">Cadastro Completo</h2>
            <p class="auth-subtitle">Preencha todos os seus dados</p>
        </div>

        <form method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Usuario.Id">
            <div class="form-columns">
                <div class="form-column">
                    <h3 class="section-title">Dados Pessoais</h3>

                    <div class="form-group">
                        <label asp-for="Usuario.Nome" class="form-label">Nome</label>
                        <input asp-for="Usuario.Nome" type="text" class="form-input" placeholder="Seu nome" required />
                        <span asp-validation-for="Usuario.Nome" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Usuario.Sobrenome" class="form-label">Sobrenome</label>
                        <input asp-for="Usuario.Sobrenome" type="text" class="form-input" placeholder="Sobrenome"
                               required />
                        <span asp-validation-for="Usuario.Sobrenome" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Usuario.Email" class="form-label">E-mail</label>
                        <input asp-for="Usuario.Email" type="email" class="form-input" placeholder="seu@email.com"
                               required />
                        <span asp-validation-for="Usuario.Email" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="CPF" class="form-label">CPF</label>
                        <input asp-for="CPF" type="text" class="form-input" placeholder="000.000.000-00" />
                        <span asp-validation-for="CPF" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="DataNascimento" class="form-label">Data de Nascimento</label>
                        <input asp-for="DataNascimento" type="date" class="form-input" />
                        <span asp-validation-for="DataNascimento" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Usuario.Telefone" class="form-label">Telefone</label>
                        <input asp-for="Usuario.Telefone" type="tel" class="form-input" placeholder="(11) 99999-9999" />
                        <span asp-validation-for="Usuario.Telefone" class="erroValidacao"></span>
                    </div>
                    <h3 class="section-title">Segurança</h3>
                </div>

                <div class="form-column">
                    <h3 class="section-title">Endereço Principal</h3>

                    <div class="form-group">
                        <label asp-for="CEP" class="form-label">CEP</label>
                        <input asp-for="CEP" type="text" class="form-input" placeholder="00000-000" />
                        <span asp-validation-for="CEP" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Logradouro" class="form-label">Logradouro</label>
                        <input asp-for="Logradouro" type="text" class="form-input" placeholder="Rua, Avenida, etc." />
                        <span asp-validation-for="Logradouro" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Numero" class="form-label">Número</label>
                        <input asp-for="Numero" type="text" class="form-input" placeholder="123" />
                        <span asp-validation-for="Numero" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Complemento" class="form-label">Complemento</label>
                        <input asp-for="Complemento" type="text" class="form-input" placeholder="Apto, Bloco, etc." />
                        <span asp-validation-for="Complemento" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Bairro" class="form-label">Bairro</label>
                        <input asp-for="Bairro" type="text" class="form-input" placeholder="Seu bairro" />
                        <span asp-validation-for="Bairro" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Cidade" class="form-label">Cidade</label>
                        <input asp-for="Cidade" type="text" class="form-input" placeholder="Sua cidade" />
                        <span asp-validation-for="Cidade" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Estado" class="form-label">Estado</label>
                        <input asp-for="Estado" type="text" class="form-input" placeholder="SP" maxlength="2" />
                        <span asp-validation-for="Estado" class="erroValidacao"></span>
                    </div>

                    <div class="form-group">
                        <input asp-for="Principal" type="checkbox" />
                        <label asp-for="Principal">Endereço Principal</label>
                    </div>
                </div>
            </div>

            <button type="submit" class="auth-button">
                <span class="button-text">Cadastrar</span>
                <span class="button-loader">
                </span>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}