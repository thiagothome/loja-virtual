@page "{pedidoId:int}"
@model SiteAspas.Pages.PagamentoPixModel
@{
    ViewData["Title"] = "Pagamento via PIX";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/pagamentoPix.css">
}

<div class="pix-container">
    <div class="pix-card">
        <div class="pix-header">
            <h1 class="pix-title">Pagamento via PIX</h1>
            <p class="pix-subtitle">Realize o pagamento para confirmar seu pedido</p>
        </div>

        <div class="pix-body">
            <!-- Informações do pedido -->
            <div class="order-info">
                <div class="order-number">
                    <span class="info-label">Número do pedido</span>
                    <span class="info-value">#@Model.PedidoId</span>
                </div>
                <div class="order-status">
                    <span class="info-label">Status</span>
                    <span class="status-value">Aguardando pagamento</span>
                </div>
            </div>

            <!-- QR Code e Instruções lado a lado -->
            <div class="qr-code-container">
                <div class="qr-code-border">
                    <img src="data:image/png;base64,@Model.QrCodeBase64" alt="QR Code PIX" class="qr-code-img">
                    <p class="qr-code-instruction">Abra o app do seu banco e escaneie este código</p>
                </div>

                <div class="instructions">
                    <h4 class="instructions-title">
                        <i class="fas fa-info-circle"></i> Como pagar:
                    </h4>
                    <ol class="steps-list">
                        <li>Abra o aplicativo do seu banco</li>
                        <li>Acesse a área PIX</li>
                        <li>Escolha "Pix Copia e Cola"</li>
                        <li>Cole o código acima e confirme</li>
                    </ol>
                </div>
            </div>

            <!-- Código PIX - agora abaixo, ocupando 4 colunas -->
            <div class="pix-code-container">
                <h3 class="pix-code-title">Ou copie o código PIX</h3>
                <div class="pix-code-wrapper">
                    <input type="text" id="pixCode" value="@Model.QrCode" readonly class="pix-code-input">
                    <button id="copyButton" class="copy-button">Copiar</button>
                </div>
            </div>


            <div class="warning-box">
                <i class="fas fa-clock warning-icon"></i>
                <div class="warning-content">
                    <h4>Prazo para pagamento</h4>
                    <p>Você tem 30 minutos para realizar o pagamento. Após esse período, o pedido será cancelado automaticamente.</p>
                </div>
            </div>

            <!-- Rodapé -->
            <div class="pix-footer">
                <a href="/" class="back-link">
                    <i class="fas fa-arrow-left"></i> Voltar para a loja
                </a>
                <div id="countdown" class="countdown"></div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const pixCode = document.getElementById('pixCode');
        const copyButton = document.getElementById('copyButton');

        copyButton.addEventListener('click', async function () {
            try {
                await navigator.clipboard.writeText(pixCode.value);

                const originalText = copyButton.innerHTML;
                copyButton.innerHTML = '<i class="bi bi-check"></i> Copiado!';
                copyButton.classList.add('btn-success');
                copyButton.classList.remove('btn-primary');

                setTimeout(() => {
                    copyButton.innerHTML = originalText;
                    copyButton.classList.remove('btn-success');
                    copyButton.classList.add('btn-primary');
                }, 2000);
            } catch (err) {

                pixCode.select();
                document.execCommand('copy');


                const originalText = copyButton.innerHTML;
                copyButton.innerHTML = 'Copiado (método antigo)';
                setTimeout(() => {
                    copyButton.innerHTML = originalText;
                }, 2000);
            }
        });
    });
</script>