@page
@model SiteAspas.Pages.PagamentoModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Pagamento";
}

@section Styles {
    <link rel="stylesheet" href="/css/pages/pagamento.css" />
}

<div class="pagamento-container">
    <div class="pagamento-card">
        <div class="pagamento-header">
            <h1 class="pagamento-title">Escolha a forma de pagamento</h1>
        </div>

        <div class="metodos-pagamento">
            <form method="post" asp-page-handler="ProcessarPagamento">
                @Html.AntiForgeryToken()
                <input type="hidden" name="pedidoId" value="@Model.PedidoId" />

                <div class="metodo">
                    <input type="radio" id="cartao" name="metodo" value="cartao" checked>
                    <label for="cartao">Cartão de Crédito</label>

                    <div class="detalhes-cartao">
                        <div class="form-group">
                            <label for="numeroCartao">Número do Cartão</label>
                            <input type="text" id="numeroCartaoMascarado" class="form-control" placeholder="**** **** **** 3456">
                            <input type="hidden" id="numeroCartao" name="numeroCartao">
                            <span id="bandeiraCartao" class="bandeira-cartao"></span>
                            <small id="mensagemCartaoInvalido" class="mensagem-erro" style="display:none; color: red;">
                                Número do cartão inválido.
                            </small>
                        </div>



                        <div class="form-row">
                            <div class="form-group">
                                <label for="validade">Validade</label>
                                <input type="text" id="validade" name="validade" class="form-control" placeholder="MM/AA" maxlength="5">
                            </div>

                            <div class="form-group">
                                <label for="cvv">CVV</label>
                                <input type="text" id="cvv" name="cvv" class="form-control" placeholder="123">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="nomeTitular">Nome do Titular</label>
                            <input type="text" id="nomeTitular" name="nomeTitular" class="form-control" placeholder="Como no cartão">
                        </div>

                        <div class="form-group">
                            <label for="parcelas">Parcelas</label>
                            <select id="parcelas" name="parcelas" class="form-control">
                                <option value="1">1x sem juros</option>
                                <option value="2">2x sem juros</option>
                                <option value="3">3x sem juros</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="metodo">
                    <input type="radio" id="pix" name="metodo" value="pix">
                    <label for="pix">PIX</label>
                    <div class="detalhes-pix" style="display: none;">
                        <p>Após confirmar o pedido, você receberá um QR Code para pagamento.</p>
                    </div>
                </div>

                <div class="metodo">
                    <input type="radio" id="boleto" name="metodo" value="boleto">
                    <label for="boleto">Boleto Bancário</label>
                    <div class="detalhes-boleto" style="display: none;">
                        <p>O boleto será gerado e enviado para seu e-mail.</p>
                    </div>
                </div>

                <div class="total-pagamento">
                    <strong>Total a pagar:</strong> @Model.Total
                </div>

                <button type="submit" class="btn-confirmar-pagamento">Confirmar Pagamento</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/cleave.js@1.6.0/dist/cleave.min.js"></script>
    <script>
        document.getElementById('validade').addEventListener('blur', function () {
            const input = this.value.trim();
            const regex = /^(0[1-9]|1[0-2])\/\d{2}$/;

            const [mes, ano] = input.split('/').map(Number);
            const dataAtual = new Date();
            const mesAtual = dataAtual.getMonth() + 1;
            const anoAtual = dataAtual.getFullYear() % 100;

            if (ano < anoAtual || (ano === anoAtual && mes < mesAtual)) {
                alert('A validade deve ser igual ou posterior ao mês atual.');
                this.focus();
            }
        });

        const inputMascarado = document.getElementById('numeroCartaoMascarado');
        const inputReal = document.getElementById('numeroCartao');
        const bandeiraSpan = document.getElementById('bandeiraCartao');
        const mensagemErro = document.getElementById('mensagemCartaoInvalido');

        const cleave = new Cleave(inputMascarado, {
            creditCard: true,
            onCreditCardTypeChanged: function (type) {
                bandeiraSpan.textContent = type !== 'unknown' ? type : '';
            }
        });

        inputMascarado.addEventListener('input', function () {
            const raw = cleave.getRawValue();
            inputReal.value = raw;

            const bandeira = detectarBandeira(raw);
            bandeiraSpan.textContent = bandeira !== 'Desconhecida' ? bandeira : '';

            mensagemErro.style.display = 'none';
        });

                inputMascarado.addEventListener('blur', function () {
            const numeroReal = inputReal.value;

            if (numeroReal.length >= 4) {
                const ultimos4 = numeroReal.slice(-4);
                const asteriscos = '*'.repeat(numeroReal.length - 4);
                const mascarado = aplicarMascaraAsterisco(asteriscos + ultimos4);
                inputMascarado.value = mascarado;
            }

            if (!validarCartao(numeroReal)) {
                mensagemErro.style.display = 'block';
            } else {
                mensagemErro.style.display = 'none';
            }
        });


        function aplicarMascaraAsterisco(valor) {
            return valor.replace(/(.{4})/g, '$1 ').trim();
        }

        function validarCartao(numero) {
            let soma = 0;
            let par = false;

            for (let i = numero.length - 1; i >= 0; i--) {
                let n = parseInt(numero.charAt(i), 10);
                if (par) {
                    n *= 2;
                    if (n > 9) n -= 9;
                }
                soma += n;
                par = !par;
            }

            return (soma % 10) === 0;
        }

        function detectarBandeira(numero) {
            if (!numero) return "Desconhecida";

            const bandeiras = [
                { pattern: /^4\d{0,15}/, name: "Visa" },
                { pattern: /^5[1-5]\d{0,14}/, name: "Mastercard" },
                { pattern: /^2\d{0,15}/, name: "Mastercard" },
                { pattern: /^3[47]\d{0,13}/, name: "Amex" },
                { pattern: /^3(0[0-5]|[68])\d{0,12}/, name: "Diners" },
                { pattern: /^6(011|5)\d{0,14}/, name: "Discover" },
                { pattern: /^(50|63|64|65)\d{0,14}/, name: "Elo" },
                { pattern: /^38\d{0,13}/, name: "Hipercard" },
                { pattern: /^35\d{0,13}/, name: "JCB" }
            ];

            for (const bandeira of bandeiras) {
                if (bandeira.pattern.test(numero)) {
                    return bandeira.name;
                }
            }

            return "Desconhecida";
        }
    </script>
}
