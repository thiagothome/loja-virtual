@page
@model SiteAspas.Pages.Pagamento.IndexModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Pagamento";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/pagamento.css" asp-append-version="true" />
}

@if (!Model.Itens.Any())
{
    <p>Seu carrinho está vazio.</p>
}

<div class="auth-container">

    <div class="auth-card pagamento-card">

        <div class="auth-header">
            <h2 class="auth-title">Pagamento</h2>
            <p class="auth-subtitle">
                Confira seu pedido antes de concluir a compra.
            </p>
        </div>

        <div class="auth-form">

            <form method="post">

                @foreach (var item in Model.Itens)
                {
                    <div class="item-carrinho">

                        <img src="@item.ImagemUrl" alt="@item.Nome" class="produto-img" />

                        <div class="produto-info">

                            <h5>@item.Nome</h5>

                            <p>
                                Quantidade:
                                <strong>@item.Quantidade</strong>
                            </p>

                            <p>
                                Valor unitário:
                                <strong>@item.Preco?.ToString("C")</strong>
                            </p>

                        </div>

                        <div class="produto-total">

                            <span>Subtotal</span>

                            <strong>
                                @(((item.Preco ?? 0) * item.Quantidade).ToString("C"))
                            </strong>

                        </div>

                    </div>

                }

                <hr />

                <div class="total-container">

                    <div class="total-container">

                        <div>

                            <p>
                                Subtotal:
                                <strong id="subtotal">
                                    @Model.Total.ToString("C")
                                </strong>
                            </p>

                            <p>
                                Frete selecionado:
                                <strong id="valorFrete">
                                    R$ 0,00
                                </strong>
                            </p>

                            <h3>

                                Total Geral:

                                <span id="totalGeral">
                                    @Model.Total.ToString("C")
                                </span>

                            </h3>

                        </div>

                    </div>

                </div>

                <hr />

                <div class="bloco">

                    <h3>Endereço de entrega</h3>

                    @if (Model.EnderecoPrincipal != null)
                    {
                        <p>
                            <strong>
                                @Model.EnderecoPrincipal.Logradouro,
                                @Model.EnderecoPrincipal.Numero
                            </strong>
                        </p>

                        @if (!string.IsNullOrWhiteSpace(Model.EnderecoPrincipal.Complemento))
                        {
                            <p>@Model.EnderecoPrincipal.Complemento</p>

                        }

                        <p>@Model.EnderecoPrincipal.Bairro</p>

                        <p>
                            @Model.EnderecoPrincipal.Cidade -
                            @Model.EnderecoPrincipal.Estado
                        </p>

                        <p>CEP: @Model.EnderecoPrincipal.CEP</p>

                    }

                </div>

                <hr />

                <div class="bloco">

                    <h3>Frete</h3>

                    <p>
                        CEP destino:
                        <strong>@Model.EnderecoPrincipal?.CEP</strong>
                    </p>


                    @if (Model.OpcoesFrete.Any())
                    {
                        @foreach (var frete in Model.OpcoesFrete.Select((x, i) => new { Frete = x, Index = i }))
{
    <label class="forma">

        <input
            type="radio"
            name="ServicoId"
            value="@frete.Frete.Id"
data-preco="@frete.Frete.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)"
            data-empresa="@frete.Frete.Company"
            data-servico="@frete.Frete.Name"
            @(frete.Index == 0 ? "checked" : "") />

        <span>
            @frete.Frete.Name -
            @frete.Frete.Company

            <br />

            @frete.Frete.Price.ToString("C")

            <br />

            Prazo:
            @frete.Frete.DeliveryTime dias
        </span>

    </label>
}
                    }
                    else
                    {
                        <p>
                            Nenhuma opção de frete encontrada.
                        </p>
                    }

                </div>

                <input type="hidden" id="FreteSelecionado" name="FreteSelecionado" />

                <input type="hidden" id="Transportadora" name="Transportadora" />

                <input type="hidden" id="ServicoFrete" name="ServicoFrete" />

                <hr />

                <div class="bloco">

                    <h3>Forma de pagamento</h3>

                    <label class="forma">
                        <input type="radio" name="FormaPagamento" value="Pix" checked />

                        <span>PIX</span>
                    </label>

                    <label class="forma">
                        <input type="radio" name="FormaPagamento" value="CartaoCredito" />

                        <span>Cartão de Crédito</span>
                    </label>

                    <label class="forma">
                        <input type="radio" name="FormaPagamento" value="Boleto" />

                        <span>Boleto Bancário</span>
                    </label>

                </div>

                <div class="acoes">

                    <a asp-page="/Produto/Carrinho" class="btn-continuar">

                        Voltar ao carrinho

                    </a>

                    <button type="submit" class="btn-finalizar">

                        Continuar

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
</div>

@section Scripts {

    <script>

        document.addEventListener("DOMContentLoaded", function () {


    const subtotal =
        @Model.Total.ToString(System.Globalization.CultureInfo.InvariantCulture);

    const radios =
        document.querySelectorAll("input[name='ServicoId']");

    const lblFrete =
        document.getElementById("valorFrete");

    const lblTotal =
        document.getElementById("totalGeral");

    const hiddenFrete =
        document.getElementById("FreteSelecionado");

    const hiddenEmpresa =
        document.getElementById("Transportadora");

    const hiddenServico =
        document.getElementById("ServicoFrete");

    function atualizar(radio){

        const frete =
    parseFloat(radio.dataset.preco);

        hiddenFrete.value = frete;
        hiddenEmpresa.value = radio.dataset.empresa;
        hiddenServico.value = radio.dataset.servico;

        lblFrete.innerHTML =
            frete.toLocaleString(
                "pt-BR",
                {
                    style: "currency",
                    currency: "BRL"
                });

        const total =
            subtotal + frete;

        lblTotal.innerHTML =
            total.toLocaleString(
                "pt-BR",
                {
                    style: "currency",
                    currency: "BRL"
                });
    }

    radios.forEach(radio => {

        radio.addEventListener("change", function () {

            atualizar(this);

        });

    });

    const primeiro =
        document.querySelector("input[name='ServicoId']:checked");

    if(primeiro){

        atualizar(primeiro);

    }

});

    </script>

}