@page "{pedidoId:int}"
@model PagamentoPixModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Pagamento via PIX";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/pagamentoPix.css">
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2 class="auth-title">Pagamento via PIX</h2>
            <p class="auth-subtitle">Escaneie o QR Code ou copie o código para pagar</p>
        </div>

        <div class="pix-content">
            <div class="pix-summary">
                <div class="pix-amount">
                    <span class="amount-label">Valor total:</span>
                    <span class="amount-value">@Model.Valor.ToString("C")</span>
                </div>
                <div class="pix-order">
                    <span class="order-label">Pedido:</span>
                    <span class="order-value">#@Model.PedidoId</span>
                </div>
            </div>

            <div class="pix-qrcode-container">
                <div class="pix-qrcode">
                    <img src="data:image/png;base64,@Model.QrCodeBase64" 
                         alt="QR Code PIX" class="qrcode-image" />
                </div>
                <button class="pix-copy-btn" onclick="copiarCodigoPix()">
                    <i class="fas fa-copy"></i> Copiar Código PIX
                </button>
                <input type="hidden" id="codigoPix" value="@Model.QrCode" />
            </div>

            <div class="pix-instructions">
                <h3 class="instructions-title">Como pagar:</h3>
                <ol class="instructions-steps">
                    <li>Abra o app do seu banco</li>
                    <li>Selecione a opção PIX</li>
                    <li>Escolha "Pagar com QR Code"</li>
                    <li>Aponte a câmera para o QR Code acima</li>
                    <li>Confirme o pagamento</li>
                </ol>
            </div>

            <div class="pix-status-info">
                <i class="fas fa-info-circle"></i>
                <p>O pedido será confirmado automaticamente assim que o pagamento for aprovado.</p>
            </div>

            <div class="pix-actions">
                <form method="post" id="verificarForm" asp-page-handler="VerificarPagamento">
                    <button type="submit" class="auth-button">
                        <span class="button-text">Verificar Pagamento</span>
                        <span class="button-loader">
                            <i class="fas fa-spinner fa-spin"></i>
                        </span>
                    </button>
                </form>

                <form method="post" asp-page-handler="Cancelar" class="cancel-form">
                    <button type="submit" class="cancel-button">
                        Cancelar Pedido
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function copiarCodigoPix() {
            const codigo = document.getElementById('codigoPix').value;
            navigator.clipboard.writeText(codigo).then(() => {
                alert('Código PIX copiado! Cole no seu app de pagamentos.');
            });
        }
        
        // Verifica automaticamente a cada 30 segundos
        setInterval(() => {
            document.getElementById('verificarForm').submit();
        }, 30000);
    </script>
}