@page "{pedidoId:int}"
@model PagamentoPixModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Pagamento PIX - Modo Teste";
}

<div class="container mt-4">
    <div class="card border-primary">
        <div class="card-header bg-primary text-white">
            <h4><i class="fas fa-qrcode"></i> PAGAMENTO PIX (MODO TESTE)</h4>
        </div>

        <div class="card-body">
            <div class="alert alert-warning">
                <h5 class="alert-heading">AMBIENTE DE TESTE</h5>
                <p>Esta é uma simulação do fluxo de pagamento PIX.</p>
            </div>

            <div class="pix-payment-info p-3 mb-4 border rounded">
                <h5 class="text-center">Pedido #@Model.PedidoId</h5>
                <h3 class="text-center text-success">@Model.Valor.ToString("C")</h3>
                <div class="text-center mt-3">
                    <div class="mock-qr-code bg-light p-4 d-inline-block">
                        <i class="fas fa-qrcode fa-5x text-muted"></i>
                        <p class="mt-2 mb-0">QR Code de teste</p>
                    </div>
                </div>
                <p class="text-center mt-3">
                    <small>Código de teste: <code>@Model.CodigoTeste</code></small>
                </p>
            </div>

            <div class="text-center">
                <form method="post" class="d-inline-block">
                    <button type="submit" asp-page-handler="SimularPagamento"
                            class="btn btn-success btn-lg mr-2">
                        <i class="fas fa-check-circle"></i> Simular Pagamento
                    </button>

                    <button type="submit" asp-page-handler="Cancelar"
                            class="btn btn-outline-danger btn-lg">
                        <i class="fas fa-times-circle"></i> Cancelar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .mock-qr-code {
        border: 2px dashed #ccc;
        border-radius: 8px;
    }

    .pix-payment-info {
        background-color: #f8f9fa;
    }
</style>