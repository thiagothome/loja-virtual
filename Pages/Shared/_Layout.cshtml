<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ASPAS Brechó Pet</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen flex flex-col">
    <!-- Cabeçalho fixo -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="header-container">
            <div class="header-content">
                <!-- Logo - 1 coluna -->
                <div class="logo-col">
                    <h1 class="text-3xl font-bold text-purple-800">
                        <a href="/">ASPAS</a>
                    </h1>
                    <p class="text-sm text-gray-600">Brechó Pet</p>
                </div>
                
                <!-- Busca - 3 colunas -->
                <div class="search-col">
                    <form action="/busca" method="get">
                        <input type="text" name="termo" placeholder="Buscar produtos..." 
                               class="search-input" />
                    </form>
                </div>
            </div>
        </div>
    </header>

    <!-- Conteúdo principal -->
    <main class="flex-grow">
        @RenderBody()
    </main>

    <!-- Rodapé -->
    <footer class="bg-gray-100 py-6 mt-12">
        <div class="max-w-7xl mx-auto px-4 text-center text-gray-600">
            <p>© @DateTime.Now.Year ONG ASPAS - Todos os direitos reservados</p>
            <div class="mt-2 space-x-4">
                <a href="/sobre" class="hover:text-purple-800">Sobre Nós</a>
                <a href="/contato" class="hover:text-purple-800">Contato</a>
                <a href="/doacoes" class="hover:text-purple-800">Doações</a>
            </div>
        </div>
    </footer>

    <script src="/js/site.js"></script>
</body>
</html>