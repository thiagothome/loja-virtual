@page
@model CompraFinalizadaModel
@{
    Layout = "_Layout";
    ViewData["HideHeader"] = true;
    ViewData["Title"] = "Compra Finalizada";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/entrar.css">
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2 class="auth-title">Pedido #@Model.Pedido.Id Confirmado!</h2>
            <p class="auth-subtitle">Status: @Model.Pedido.Status</p>
        </div>
        <div class="auth-form">
            <div class="form-group">
                <h3 class="form-label">Itens do Pedido</h3>
                <ul>
                    @foreach (var item in Model.Pedido.Itens)
                    {
                        <li>@item.Quantidade x @item.Nome - @((item.Quantidade * item.PrecoUnitario).ToString("C"))</li>
                    }
                </ul>
                <div class="total" style="margin-top: 16px; font-weight: bold;">
                    Total: @Model.Pedido.Total.ToString("C")
                </div>
            </div>

            <a href="/" class="auth-button" style="text-align: center; display: block; text-decoration: none;">
                Voltar à Loja
            </a>
        </div>
    </div>
</div>
