@model (string Nome, string Link)
<html>
<body style="font-family: Arial, sans-serif;">
    <div style="max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #e0e0e0;">
        <h2 style="color: #1a73e8;">Confirme seu e-mail</h2>
        <p>Olá, @Model.Nome!</p>
        <p>Clique no botão abaixo para confirmar seu cadastro:</p>
        <a href="@Model.Link" 
           style="display: inline-block; padding: 10px 20px; background: #1a73e8; color: white; text-decoration: none; border-radius: 4px;">
            Confirmar E-mail
        </a>
        <p style="margin-top: 20px; font-size: 12px; color: #666;">
            Se você não solicitou este cadastro, ignore este e-mail.
        </p>
    </div>
</body>
</html>