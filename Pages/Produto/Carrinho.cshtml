@page
@model CarrinhoModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Carrinho de Compras";
}

@section Styles {
    <link rel="stylesheet" href="/css/pages/carrinho.css" />
}

<div class="carrinho-container">
    <h1>Carrinho de Compras</h1>

    @if (Model.Itens.Any())
    {
        <ul class="lista-itens">
            @foreach (var item in Model.Itens)
            {
                <li class="item">
                    <img src="@item.ImagemUrl" alt="@item.Nome" />
                    <div class="detalhes">
                        <h2>@item.Nome</h2>
                        <p>Preço: @item.Preco</p>
                        <p>Quantidade: @item.Quantidade</p>

                        <div class="controles-quantidade">
                            <form method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ProdutoId" />
                                <input type="hidden" name="acao" value="diminuir" />
                                <button type="submit" asp-page-handler="AtualizarQuantidade" class="btn-controle">-</button>
                            </form>

                            <form method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ProdutoId" />
                                <input type="hidden" name="acao" value="aumentar" />
                                <button type="submit" asp-page-handler="AtualizarQuantidade" class="btn-controle">+</button>
                            </form>
                        </div>

                        <form method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.ProdutoId" />
                            <button type="submit" asp-page-handler="RemoverItem" class="btn-remover">Remover</button>
                        </form>
                    </div>
                </li>
            }
        </ul>

        <div class="calculo-frete">
            <h3>Calcular Frete</h3>
            <form method="post" asp-page-handler="CalcularFrete">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="cep">CEP:</label>
                    <input type="text" id="cep" name="cep" placeholder="Digite seu CEP" required>
                </div>
                <button type="submit" class="btn-calcular">Calcular</button>
                @if (!string.IsNullOrEmpty(Model.MensagemFrete))
                {
                    <p class="@Model.ClasseMensagemFrete">@Model.MensagemFrete</p>
                }
                @if (Model.ResultadoFrete != null)
                {
                    <div class="resultado-frete">
                        <h4>Opções de Frete:</h4>
                        <ul>
                            @foreach (var frete in Model.ResultadoFrete)
                            {
                                <li>
                                    <strong>@frete.Servico:</strong> @frete.Valor.ToString("C") - Prazo: @frete.PrazoEntrega
                                    <input type="radio" name="opcaoFreteSelecionada" value="@frete.Servico" /> Selecionar
                                </li>
                            }
                        </ul>
                        <button type="submit" asp-page-handler="SelecionarFrete" class="btn-selecionar-frete">Selecionar Frete</button>
                    </div>
                }
            </form>
        </div>

        @if (Model.ValorFreteSelecionado > 0)
        {
            <div class="frete-selecionado">
                <strong>Frete (@Model.OpcaoFreteSelecionada):</strong> @Model.ValorFreteSelecionado.ToString("C")
            </div>
        }
        <div class="total">
            <strong>Total:</strong> @(Model.Total + Model.ValorFreteSelecionado)
        </div>
        <div class="acoes-carrinho">
            <form method="post" asp-page-handler="FinalizarCompra">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-finalizar">Finalizar Compra</button>
            </form>
        </div>
    }
    else
    {
        <p>Seu carrinho está vazio.</p>
    }
</div>