@page
@model SiteAspas.Pages.CarrinhoModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Meu Carrinho";
}

@section Styles {
    <link rel="stylesheet" href="/css/pages/carrinho.css" asp-append-version="true" />
}

@if (!Model.Itens.Any())
{
    <p>Seu carrinho está vazio.</p>
}
else
{
    <div class="auth-container">

    <div class="auth-card carrinho-card">

        <div class="auth-header">
            <h2 class="auth-title">Meu Carrinho</h2>
            <p class="auth-subtitle">
                Revise seus produtos antes de finalizar a compra.
            </p>
        </div>

        <div class="auth-form">

            @foreach (SiteAspas.Models.CarrinhoItem item in Model.Itens)
            {
                <div class="item-carrinho">

                    <img src="@item.ImagemUrl"
                         alt="@item.Nome"
                         class="produto-img" />

                    <div class="produto-info">

                        <h5>@item.Nome</h5>

                        <p>
                            Quantidade:
                            <strong>@item.Quantidade</strong>
                        </p>

                        <p>
                            Valor unitário:
                            <strong>@item.Preco?.ToString("C")</strong>
                        </p>

                    </div>

                    <div class="produto-total">

                        <span>Subtotal</span>

                        <strong>
                            @(((item.Preco ?? 0) * item.Quantidade).ToString("C"))
                        </strong>

                    </div>

                </div>
            }

            <hr />

            <div class="total-container">

                <div>
                    <small>Total da compra</small>
                    <h3>@Model.Total.ToString("C")</h3>
                </div>

            </div>

            <div class="acoes">

                <a asp-page="/Home/Index"
                   class="btn-continuar">
                    Continuar comprando
                </a>

               <form method="post" asp-page-handler="Finalizar">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn-finalizar">
                        Finalizar compra
                    </button>
                </form>

            </div>

        </div>

    </div>

</div>
}