@page
@model SiteAspas.Pages.CadastrarProdutoModel
@{
    Layout = "_Layout";
    ViewData["HideHeader"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/cadastrarCarrosselProduto.css">
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2 class="auth-title">Cadastrar Novo Produto</h2>
            <p class="auth-subtitle">Preencha os dados do produto</p>
        </div>

        <form method="post" enctype="multipart/form-data" class="auth-form">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Produto.Nome" class="form-label">Nome do Produto</label>
                <input asp-for="Produto.Nome" class="form-input" placeholder="Nome do produto" />
                <span asp-validation-for="Produto.Nome" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label asp-for="Produto.Descricao" class="form-label">Descrição</label>
                <textarea asp-for="Produto.Descricao" class="form-input" placeholder="Descrição do produto"
                          rows="3"></textarea>
                <span asp-validation-for="Produto.Descricao" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label asp-for="Produto.Preco" class="form-label">Preço</label>
                <input asp-for="Produto.Preco" type="number" step="0.01" class="form-input" placeholder="0.00" />
                <span asp-validation-for="Produto.Preco" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label asp-for="Produto.Estoque" class="form-label">Estoque</label>
                <input asp-for="Produto.Estoque" type="number" step="1" value="" class="form-input" placeholder="0" />
                <span asp-validation-for="Produto.Estoque" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label asp-for="Produto.Peso" class="form-label">
                    Peso (kg)
                </label>

                <input asp-for="Produto.Peso" type="number" step="0.001" class="form-input" placeholder="0.500" />

                <span asp-validation-for="Produto.Peso" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label asp-for="Produto.Altura" class="form-label">
                    Altura (cm)
                </label>

                <input asp-for="Produto.Altura" type="number" step="0.01" class="form-input" placeholder="20" />

                <span asp-validation-for="Produto.Altura" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label asp-for="Produto.Largura" class="form-label">
                    Largura (cm)
                </label>

                <input asp-for="Produto.Largura" type="number" step="0.01" class="form-input" placeholder="15" />

                <span asp-validation-for="Produto.Largura" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label asp-for="Produto.Comprimento" class="form-label">
                    Comprimento (cm)
                </label>

                <input asp-for="Produto.Comprimento" type="number" step="0.01" class="form-input" placeholder="30" />

                <span asp-validation-for="Produto.Comprimento" class="erroValidacao"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImagemProduto" class="form-label">Imagem do Produto</label>
                <input asp-for="ImagemProduto" type="file" class="form-input" />
                <span asp-validation-for="ImagemProduto" class="erroValidacao"></span>
            </div>

            <button type="submit" class="auth-button">
                <span class="button-text">Cadastrar Produto</span>
                <span class="button-loader">
                    <i class="fas fa-spinner fa-spin"></i>
                </span>
            </button>
        </form>
        <div class="auth-form">
            <a href="/" style="text-align: center; display: block; text-decoration: none;">
                Voltar à Loja
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}